# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# Required: Gemini API key for LLM parsing
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini model to use (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Optional: ILP REST endpoint (default shown below)
ILPENDPOINT=https://ilp-rest-2025-bvh6e9hschfagrgy.ukwest-01.azurewebsites.net/

# Optional: CW2 service endpoint (if running separately)
# CW2_ENDPOINT=http://localhost:8080
